{
  "name": "gh-pr-review",
  "version": "0.1.0",
  "description": "GitHub CLI extension for reading and responding to PR review comments",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bash script/build.sh",
    "typecheck": "bun run tsc --noEmit"
  },
  "keywords": ["github", "cli", "extension", "pull-request", "review"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
